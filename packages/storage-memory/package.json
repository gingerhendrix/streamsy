{
  "name": "@streamsy/storage-memory",
  "version": "0.0.1",
  "description": "In-memory Streamsy storage adapter for development, tests, and ephemeral servers.",
  "homepage": "https://github.com/gingerhendrix/streamsy#readme",
  "bugs": {
    "url": "https://github.com/gingerhendrix/streamsy/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gingerhendrix/streamsy.git",
    "directory": "packages/storage-memory"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean --external @streamsy/core",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --run src"
  },
  "dependencies": {
    "@streamsy/core": "0.0.1"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "^4.0.16"
  }
}
