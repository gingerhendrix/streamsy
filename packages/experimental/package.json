{
  "name": "@streamsy/experimental",
  "version": "0.2.0",
  "description": "Experimental primitives for Streamsy durable streams.",
  "homepage": "https://github.com/gingerhendrix/streamsy#readme",
  "bugs": {
    "url": "https://github.com/gingerhendrix/streamsy/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gingerhendrix/streamsy.git",
    "directory": "packages/experimental"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./materializer": {
      "types": "./dist/materializer.d.ts",
      "import": "./dist/materializer.js",
      "default": "./dist/materializer.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/materializer.ts --format esm --dts --out-dir dist --clean --external @streamsy/core",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --run src"
  },
  "dependencies": {
    "@streamsy/core": "0.2.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "^4.0.16"
  }
}
