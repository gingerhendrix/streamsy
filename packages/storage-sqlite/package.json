{
  "name": "@streamsy/storage-sqlite",
  "version": "0.0.2",
  "description": "Bun SQLite Streamsy storage adapter for durable local persistence.",
  "homepage": "https://github.com/gingerhendrix/streamsy#readme",
  "bugs": {
    "url": "https://github.com/gingerhendrix/streamsy/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gingerhendrix/streamsy.git",
    "directory": "packages/storage-sqlite"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --out-dir dist --clean --external @streamsy/core --external bun:sqlite",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test src"
  },
  "dependencies": {
    "@streamsy/core": "0.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "catalog:"
  }
}
