{
  "name": "hackernews-newest-stream",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build && bun run src/server/index.ts",
    "dev:api": "bun run src/server/index.ts",
    "build": "bun run src/server/build-client.ts",
    "start": "bun run build && bun run src/server/index.ts",
    "smoke:http": "bun run scripts/http-smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@durable-streams/state": "^0.3.1",
    "@streamsy/core": "workspace:*",
    "@streamsy/storage-memory": "workspace:*",
    "@tanstack/db": "0.6.8",
    "@tanstack/react-db": "^0.1.83",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "catalog:",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
